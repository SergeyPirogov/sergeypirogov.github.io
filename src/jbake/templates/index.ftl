    <script>
      document.getElementById("cta-form").addEventListener("submit", function(e) {
        e.preventDefault();
        var form = this;
        var formData = new FormData(form);
        var status = document.getElementById("cta-form-status");

        fetch(form.action, {
          method: 'POST',
          body: formData
        })
        .then(response => {
          if (response.ok) {
            status.innerHTML = "✓ Thank you! I'll get back to you soon.";
            status.classList.add('success');
            form.reset();
          } else {
            status.innerHTML = "Error sending message. Please try again.";
            status.classList.add('error');
          }
        })
        .catch(error => {
          status.innerHTML = "Error sending message. Please try again.";
          status.classList.add('error');
        });
      });
    </script>

